# ── GitLab ────────────────────────────────────────────────────
# Personal Access Token with api scope
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
# Base URL of your GitLab instance (no trailing slash)
GITLAB_BASE_URL=https://gitlab.com
# The GitLab group / namespace that owns all 18 repos
GITLAB_GROUP=kreasipositif
# Polling interval in seconds (default: 60)
POLL_INTERVAL_SECONDS=60

# ── Database ──────────────────────────────────────────────────
# Set SPRING_PROFILES_ACTIVE=prod to switch from H2 (dev) → PostgreSQL (prod)
SPRING_PROFILES_ACTIVE=dev
DB_URL=jdbc:postgresql://localhost:5432/repocity
DB_USERNAME=repocity
DB_PASSWORD=change_me

# ── Application ───────────────────────────────────────────────
SERVER_PORT=8080
